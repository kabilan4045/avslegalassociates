// This is your Prisma schema file for AVS Legal Associates
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  // Client info
  name              String
  email             String
  phone             String
  legal_query       String?
  query             String?   // legacy column

  // Consultation info
  consultation_type String?   // 'doubt' | 'quick' | 'detailed'
  plan              String?   // legacy column

  // Pricing
  amount            Int       // paise (e.g. 50000 = ₹500)

  // Payment
  payment_id        String?   @unique
  order_id          String?
  payment_status    String    @default("pending")   // 'pending' | 'paid' | 'failed'
  status            String?   // legacy column

  // Scheduling
  selected_date     DateTime? @db.Date
  selected_time     String?
  date              String?   // legacy column
  time              String?   // legacy column

  // Cal.com
  cal_booking_uid   String?
  meeting_url       String?

  // Booking state
  booking_status    String    @default("pending")   // 'pending' | 'confirmed' | 'cancelled'
  email_sent        Boolean   @default(false)
  webhook_verified  Boolean   @default(false)

  @@map("bookings")
  @@index([payment_status])
  @@index([booking_status])
  @@index([selected_date])
  @@index([consultation_type])
  @@index([email])
  @@index([created_at(sort: Desc)])
}
